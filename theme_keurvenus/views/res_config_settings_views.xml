<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_theme_keurvenus_auth" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.theme.keurvenus.auth</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <setting id="checkout_registration_setting" position="after">
                <setting
                    id="theme_keurvenus_auth_mode_setting"
                    string="Connexion storefront Kër Venus"
                    help="Choose whether storefront customers sign in with email or phone."
                    website_dependent="1">
                    <field name="theme_keurvenus_auth_mode" widget="radio"/>
                </setting>
            </setting>
        </field>
    </record>
</odoo>
