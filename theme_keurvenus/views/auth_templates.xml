<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_keurvenus_login" inherit_id="web.login" name="Theme Keur Venus Login">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="website.layout">
                <t t-set="pageName" t-value="'theme-keurvenus-login'"/>
                <t t-set="title" t-value="'Connexion - K\u00ebr Venus'"/>
                <t t-set="no_footer" t-value="True"/>
                <div id="wrap" class="oe_structure kv-auth-page">
                    <section class="kv-auth-shell kv-auth-shell--login">
                        <article class="kv-panel kv-auth-form">
                            <div>
                                <div class="kv-eyebrow kv-eyebrow--light">
                                    <iconify-icon icon="solar:login-2-linear"/>
                                    connexion
                                </div>
                                <h1>Heureux de vous revoir.</h1>
                                <p>Connectez-vous pour retrouver vos favoris, finaliser vos commandes et continuer votre experience Ker Venus sans interruption.</p>
                            </div>

                            <div class="kv-auth-social">
                                <t t-call="web.login_oauth"/>
                            </div>

                            <form t-attf-class="oe_login_form kv-form-grid #{'kv-form-grid--with-db' if databases and len(databases) &gt; 1 else 'kv-form-grid--single'}" role="form" t-attf-action="/web/login" method="post" onsubmit="this.action = '/web/login' + location.hash" data-captcha="login">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input t-if="request.db and not (databases and len(databases) &gt; 1)" type="hidden" name="db" t-att-value="request.db"/>

                                <div class="kv-form-field" t-if="databases and len(databases) &gt; 1">
                                    <label for="db">Base de donnees</label>
                                    <div class="kv-input-wrap">
                                        <iconify-icon icon="solar:database-linear"/>
                                        <input type="text" name="db" t-att-value="request.db" id="db" required="required" readonly="readonly"/>
                                        <a role="button" href="/web/database/selector" class="kv-inline-link">Choisir</a>
                                    </div>
                                </div>

                                <div t-attf-class="kv-form-field #{'' if databases and len(databases) &gt; 1 else 'kv-form-field--full'}">
                                    <label for="login">Adresse e-mail</label>
                                    <div class="kv-input-wrap">
                                        <iconify-icon icon="solar:letter-linear"/>
                                        <input type="text" placeholder="vous@exemple.com" name="login" t-att-value="login" id="login" required="required" autocapitalize="off" autocomplete="username"/>
                                    </div>
                                </div>

                                <div class="kv-form-field kv-form-field--full">
                                    <label for="password">Mot de passe</label>
                                    <div class="kv-input-wrap input-group">
                                        <iconify-icon icon="solar:lock-password-linear"/>
                                        <input type="password" placeholder="Votre mot de passe" name="password" id="password" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" maxlength="4096"/>
                                        <button type="button" class="o_show_password kv-password-toggle">
                                            <i class="fa fa-eye"/>
                                        </button>
                                    </div>
                                </div>

                                <p class="alert alert-danger kv-form-field--full" t-if="error" role="alert"><t t-esc="error"/></p>
                                <p class="alert alert-success kv-form-field--full" t-if="message" role="status"><t t-esc="message"/></p>

                                <div class="kv-auth-row kv-form-field--full">
                                    <span class="kv-auth-row__spacer"/>
                                    <a t-if="reset_password_enabled" t-attf-href="/web/reset_password?{{ keep_query() }}" class="kv-auth-aux-link">Mot de passe oublie ?</a>
                                </div>

                                <div class="oe_login_buttons kv-auth-actions kv-form-field--full">
                                    <button type="submit" class="kv-cta-primary kv-cta-primary--wide">Se connecter <iconify-icon icon="solar:arrow-right-linear"/></button>
                                    <a t-if="signup_enabled" t-attf-href="/web/signup?{{ keep_query() }}" class="kv-cta-secondary kv-cta-primary--wide">Creer un compte</a>
                                    <t t-if="debug">
                                        <button type="submit" name="redirect" value="/web/become" class="kv-auth-debug-link">Connexion superutilisateur</button>
                                    </t>
                                </div>

                                <input type="hidden" name="type" value="password"/>
                                <input type="hidden" name="redirect" t-att-value="redirect"/>
                            </form>

                            <div class="kv-auth-links kv-auth-links--footnote">
                                <span>Vous n'avez pas encore de compte ?</span>
                                <a t-if="signup_enabled" t-attf-href="/web/signup?{{ keep_query() }}">Creer un compte</a>
                            </div>
                        </article>

                        <article class="kv-panel kv-auth-visual kv-auth-visual--login">
                            <div>
                                <div class="kv-eyebrow">
                                    <iconify-icon icon="solar:star-shine-linear"/>
                                    maison &amp; elegance
                                </div>
                                <h2>Retrouvez votre univers, vos envies et vos selections.</h2>
                                <p>Ker Venus vous accompagne dans une experience d'achat plus personnelle, plus fluide et plus inspirante autour de la maison.</p>
                            </div>
                            <div class="kv-auth-benefits">
                                <div><iconify-icon icon="solar:heart-linear"/><span>Accedez a votre wishlist enregistree.</span></div>
                                <div><iconify-icon icon="solar:box-linear"/><span>Suivez vos commandes et leur livraison.</span></div>
                                <div><iconify-icon icon="solar:gift-linear"/><span>Recevez plus vite les nouveautes de la marque.</span></div>
                            </div>
                        </article>
                    </section>
                </div>
            </t>
        </xpath>
    </template>

    <template id="theme_keurvenus_signup" inherit_id="auth_signup.signup" name="Theme Keur Venus Signup">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="website.layout">
                <t t-set="pageName" t-value="'theme-keurvenus-signup'"/>
                <t t-set="title" t-value="'Creer un compte - K\u00ebr Venus'"/>
                <t t-set="no_footer" t-value="True"/>
                <div id="wrap" class="oe_structure kv-auth-page">
                    <section class="kv-auth-shell kv-auth-shell--signup">
                        <article class="kv-panel kv-auth-visual kv-auth-visual--signup">
                            <div>
                                <div class="kv-eyebrow">
                                    <iconify-icon icon="solar:user-plus-linear"/>
                                    creer un compte
                                </div>
                                <h2>Entrez dans l'univers Ker Venus.</h2>
                                <p>Creez votre compte pour enregistrer vos coups de coeur, suivre vos commandes et retrouver plus facilement vos collections maison preferees.</p>
                            </div>
                            <div class="kv-auth-benefits">
                                <div><iconify-icon icon="solar:heart-linear"/><span>Wishlist synchronisee entre vos appareils.</span></div>
                                <div><iconify-icon icon="solar:bag-4-linear"/><span>Historique de commandes et panier memorise.</span></div>
                                <div><iconify-icon icon="solar:gift-linear"/><span>Acces anticipe aux nouvelles collections et offres.</span></div>
                            </div>
                        </article>

                        <article class="kv-panel kv-auth-form">
                            <div>
                                <h1>Creer mon compte</h1>
                                <p>Renseignez vos informations pour commencer une experience maison plus fluide, plus personnelle et plus raffinee.</p>
                            </div>

                            <form class="oe_signup_form kv-form-grid" role="form" method="post" t-if="not message" data-captcha="signup">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="kv-form-field kv-form-field--full">
                                    <label for="name">Nom complet</label>
                                    <div class="kv-input-wrap">
                                        <iconify-icon icon="solar:user-rounded-linear"/>
                                        <input type="text" name="name" t-att-value="name" id="name" placeholder="Votre nom" autofocus="autofocus" required="required" t-att-readonly="'readonly' if token and not invalid_token else None"/>
                                    </div>
                                </div>

                                <div class="kv-form-field kv-form-field--full">
                                    <label for="login">Adresse e-mail</label>
                                    <div class="kv-input-wrap">
                                        <iconify-icon icon="solar:letter-linear"/>
                                        <input type="text" name="login" t-att-value="login" id="login" autocapitalize="off" required="required" placeholder="vous@exemple.com" t-att-readonly="'readonly' if token and not invalid_token else None"/>
                                    </div>
                                </div>

                                <div class="kv-form-field">
                                    <label for="password">Mot de passe</label>
                                    <div class="kv-input-wrap">
                                        <iconify-icon icon="solar:lock-password-linear"/>
                                        <input type="password" name="password" id="password" required="required" t-att-autofocus="'autofocus' if token and not invalid_token else None"/>
                                    </div>
                                </div>

                                <div class="kv-form-field">
                                    <label for="confirm_password">Confirmer le mot de passe</label>
                                    <div class="kv-input-wrap">
                                        <iconify-icon icon="solar:lock-password-linear"/>
                                        <input type="password" name="confirm_password" id="confirm_password" required="required"/>
                                    </div>
                                </div>

                                <p class="alert alert-danger kv-form-field--full" t-if="error" role="alert"><t t-esc="error"/></p>

                                <input type="hidden" name="redirect" t-att-value="redirect"/>
                                <input type="hidden" name="token" t-att-value="token"/>

                                <div class="oe_login_buttons kv-auth-actions kv-form-field--full">
                                    <button type="submit" class="kv-cta-primary kv-cta-primary--wide">Creer mon compte <iconify-icon icon="solar:arrow-right-linear"/></button>
                                    <a t-attf-href="/web/login?{{ keep_query() }}" class="kv-cta-secondary">J'ai deja un compte</a>
                                    <t t-call="web.login_oauth"/>
                                </div>
                            </form>

                            <div class="oe_structure" id="oe_structure_signup_bottom"/>
                        </article>
                    </section>
                </div>
            </t>
        </xpath>
    </template>

    <template id="theme_keurvenus_reset_password" inherit_id="auth_signup.reset_password" name="Theme Keur Venus Reset Password">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="website.layout">
                <t t-set="pageName" t-value="'theme-keurvenus-reset-password'"/>
                <t t-set="title" t-value="'Reinitialiser le mot de passe - K\u00ebr Venus'"/>
                <t t-set="no_footer" t-value="True"/>
                <div id="wrap" class="oe_structure kv-auth-page">
                    <section class="kv-auth-shell kv-auth-shell--login">
                        <article class="kv-panel kv-auth-form">
                            <div>
                                <div class="kv-eyebrow kv-eyebrow--light">
                                    <iconify-icon icon="solar:key-linear"/>
                                    securite
                                </div>
                                <h1>Reinitialiser mon acces</h1>
                                <p>Recevez un lien de reinitialisation ou choisissez un nouveau mot de passe pour retrouver rapidement votre espace Ker Venus.</p>
                            </div>

                            <div t-if="message" class="oe_login_form clearfix">
                                <p class="alert alert-success" role="status"><t t-esc="message"/></p>
                                <a href="/web/login" class="kv-cta-secondary" role="button">Retour a la connexion</a>
                            </div>

                            <form class="oe_reset_password_form kv-form-grid" role="form" method="post" t-if="not message" data-captcha="password_reset">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <t t-if="token and not invalid_token">
                                    <div class="kv-form-field">
                                        <label for="password">Nouveau mot de passe</label>
                                        <div class="kv-input-wrap">
                                            <iconify-icon icon="solar:lock-password-linear"/>
                                            <input type="password" name="password" id="password" required="required" autofocus="autofocus"/>
                                        </div>
                                    </div>
                                    <div class="kv-form-field">
                                        <label for="confirm_password">Confirmer le mot de passe</label>
                                        <div class="kv-input-wrap">
                                            <iconify-icon icon="solar:lock-password-linear"/>
                                            <input type="password" name="confirm_password" id="confirm_password" required="required"/>
                                        </div>
                                    </div>
                                </t>

                                <t t-if="not token">
                                    <div class="kv-form-field kv-form-field--full">
                                        <label for="login">Adresse e-mail</label>
                                        <div class="kv-input-wrap">
                                            <iconify-icon icon="solar:letter-linear"/>
                                            <input type="text" name="login" t-att-value="login" id="login" autofocus="autofocus" required="required" autocapitalize="off"/>
                                        </div>
                                    </div>
                                </t>

                                <p class="alert alert-danger kv-form-field--full" t-if="error" role="alert"><t t-esc="error"/></p>
                                <input type="hidden" name="redirect" t-att-value="redirect"/>
                                <input type="hidden" name="token" t-att-value="token"/>

                                <div class="oe_login_buttons kv-auth-actions kv-form-field--full">
                                    <button type="submit" class="kv-cta-primary kv-cta-primary--wide">Reinitialiser <iconify-icon icon="solar:arrow-right-linear"/></button>
                                    <div class="kv-auth-links">
                                        <a t-if="not token" t-attf-href="/web/login?{{ keep_query() }}">Retour a la connexion</a>
                                        <a t-if="invalid_token" href="/web/login">Retour a la connexion</a>
                                    </div>
                                    <t t-call="web.login_oauth"/>
                                </div>
                            </form>
                        </article>

                        <article class="kv-panel kv-auth-visual kv-auth-visual--reset">
                            <div>
                                <div class="kv-eyebrow">
                                    <iconify-icon icon="solar:shield-check-linear"/>
                                    confiance &amp; serenite
                                </div>
                                <h2>Votre espace reste protegee, votre experience reste fluide.</h2>
                                <p>Nous vous aidons a retrouver l'acces a votre compte sans casser la qualite du parcours ni la coherence visuelle du theme.</p>
                            </div>
                            <div class="kv-auth-benefits">
                                <div><iconify-icon icon="solar:letter-linear"/><span>Reinitialisation envoyee par e-mail.</span></div>
                                <div><iconify-icon icon="solar:shield-check-linear"/><span>Mot de passe mis a jour de facon securisee.</span></div>
                                <div><iconify-icon icon="solar:heart-linear"/><span>Wishlist, panier et commandes retrouves en quelques instants.</span></div>
                            </div>
                        </article>
                    </section>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
