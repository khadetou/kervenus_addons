<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_keurvenus_portal_password_wizard_form" model="ir.ui.view">
        <field name="name">keurvenus.portal.password.wizard.form</field>
        <field name="model">keurvenus.portal.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Acces portail et mot de passe">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="user_id" readonly="1"/>
                        <field name="user_state" readonly="1"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <field name="notice" nolabel="1"/>
                    </div>
                    <group>
                        <field name="login" placeholder="client@exemple.com"/>
                        <field name="password" password="True"/>
                        <field name="confirm_password" password="True"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" string="Enregistrer l'acces" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_partner_form_portal_password_button" model="ir.ui.view">
        <field name="name">res.partner.form.keurvenus.portal.password</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_keurvenus_portal_password_wizard"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-key"
                    groups="base.group_system"
                    invisible="not id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Portail</span>
                        <span class="o_stat_text">Mot de passe</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_portal_wizard_password_fields" model="ir.ui.view">
        <field name="name">portal.wizard.password.fields</field>
        <field name="model">portal.wizard</field>
        <field name="inherit_id" ref="portal.wizard_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']/list/field[@name='login_date']" position="after">
                <field name="user_id" column_invisible="True"/>
                <field name="new_password" string="Nouveau mot de passe" password="True" groups="base.group_system"/>
                <field name="confirm_password" string="Confirmation" password="True" groups="base.group_system"/>
                <button
                    string="Modifier mot de passe"
                    name="action_set_portal_password"
                    type="object"
                    class="btn-primary"
                    groups="base.group_system"
                    invisible="email_state != 'ok'"/>
            </xpath>
        </field>
    </record>
</odoo>
