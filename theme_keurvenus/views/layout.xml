<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_keurvenus_layout" inherit_id="website.layout" name="Theme Keur Venus Layout">
        <xpath expr="//head" position="inside">
            <meta name="theme-color" content="#f3ede4"/>
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
            <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,500&amp;family=Cormorant+Garamond:wght@500;600;700&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            <link rel="icon" type="image/svg+xml" href="/theme_keurvenus/static/src/img/keurvenus/logo.svg"/>
            <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" defer="defer"/>
        </xpath>
        <body position="before">
            <t t-set="body_classname" t-value="'theme-keurvenus' + (' ' + body_classname if body_classname else '')"/>
        </body>
        <xpath expr="//div[@id='wrapwrap']" position="attributes">
            <attribute name="t-attf-class" add="theme-keurvenus-wrap" separator=" "/>
        </xpath>
    </template>
</odoo>
