<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- ============================================================ -->
    <!-- 1. Change Page Title from "Odoo" to "Saytu" -->
    <!-- ============================================================ -->
    <template id="saytu_layout" inherit_id="web.layout">
        <xpath expr="//title" position="replace">
            <title t-esc="title or 'Saytu'"/>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- 2. Remove "Powered by Odoo" from Login Page Footer -->
    <!-- ============================================================ -->
    <template id="saytu_login_layout" inherit_id="web.login_layout">
        <!-- Remove the "Powered by Odoo" link -->
        <xpath expr="//div[@class='text-center small mt-4 pt-3 border-top']/a[@href='https://www.odoo.com?utm_source=db&amp;utm_medium=auth']" position="replace">
            <!-- Optionally add Saytu branding here -->
            <span class="text-muted">Powered by Saytu</span>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- 3. Remove "Powered by Odoo" Brand Promotion Message -->
    <!-- ============================================================ -->
    <template id="brand_promotion_message" inherit_id="web.brand_promotion_message" name="Saytu Brand Promotion Message">
        <!-- Replace the odoo_logo variable -->
        <xpath expr="//t[@t-set='odoo_logo']" position="replace">
            <t t-set="odoo_logo">
                <span class="badge text-bg-light">Saytu</span>
            </t>
        </xpath>
    </template>

</odoo>

